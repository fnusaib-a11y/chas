rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        (request.auth.token.email_verified == true && request.auth.token.email == "fnusaib@gmail.com")
      );
    }

    // Entity validations
    function isValidUser(data) {
      return data.id is string && data.id.size() <= 128
          && data.name is string && data.name.size() <= 100
          && data.phone is string && data.phone.size() <= 100
          && data.referralCode is string && data.referralCode.size() <= 50
          && data.balance is number
          && data.pendingBalance is number
          && data.bonusBalance is number
          && data.totalTasksCompleted is number
          && data.totalReferrals is number
          && data.level is number
          && data.createdAt is string;
    }

    function isValidTaskLog(data) {
      return data.userId is string && data.userId.size() <= 128
          && data.taskId is string && data.taskId.size() <= 128
          && data.completedAt is string
          && data.reward is number
          && data.status is string;
    }

    function isValidTransaction(data) {
      return data.userId is string && data.userId.size() <= 128
          && data.amount is number
          && data.type is string
          && data.description is string
          && data.status is string
          && data.createdAt is string;
    }

    function isValidWithdrawal(data) {
      return data.userId is string && data.userId.size() <= 128
          && data.amount is number
          && data.method is string
          && data.details is string
          && data.status is string
          && data.createdAt is string;
    }

    function isValidOrder(data) {
      return data.userId is string && data.userId.size() <= 128
          && data.items is list
          && data.totalPrice is number
          && data.address is string
          && data.status is string
          && data.createdAt is string;
    }

    function isValidGroupMessage(data) {
      return data.groupId is string && data.groupId.size() <= 128
          && data.senderId is string && data.senderId.size() <= 128
          && data.senderName is string && data.senderName.size() <= 100
          && data.text is string && data.text.size() <= 5000
          && data.createdAt is string;
    }

    function isValidDirectMessage(data) {
      return data.participants is list && data.participants.size() == 2
          && data.senderId is string && data.senderId.size() <= 128
          && data.senderName is string && data.senderName.size() <= 100
          && data.recipientId is string && data.recipientId.size() <= 128
          && data.text is string && data.text.size() <= 5000
          && data.createdAt is string;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() <= 200
          && data.price is number && data.price >= 0
          && data.status is string;
    }

    function isValidServiceBooking(data) {
      return data.userId is string && data.userId.size() <= 128
          && data.providerId is string && data.providerId.size() <= 128
          && data.price is number
          && data.status is string;
    }

    function isValidCourierOrder(data) {
      return data.userId is string && data.userId.size() <= 128
          && data.price is number
          && data.status is string;
    }

    function isValidStudentResource(data) {
      return data.userId is string && data.userId.size() <= 128
          && data.title is string && data.title.size() <= 200
          && data.price is number;
    }

    function isValidAIContentRequest(data) {
      return data.userId is string && data.userId.size() <= 128
          && data.type is string
          && data.prompt is string;
    }

    function isValidAIAsset(data) {
      return data.ownerId is string && data.ownerId.size() <= 128
          && data.title is string && data.title.size() <= 200
          && data.price is number;
    }

    // Rules for Collections
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && incoming().balance == 0 && incoming().pendingBalance == 0 && incoming().bonusBalance == 0 && incoming().totalTasksCompleted == 0 && incoming().totalReferrals == 0 && (!('isAdmin' in incoming()) || incoming().isAdmin == false);
      allow update: if (isAdmin() || (isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['darkMode', 'soundEnabled', 'avatar', 'avatarConfig', 'stylePreferences', 'uiTheme', 'coverPhoto', 'bio']) ||
        incoming().diff(existing()).affectedKeys().hasOnly(['kycStatus', 'kycFullName', 'kycNidOrPassport', 'kycPaymentNumber', 'kycFacebookPhone', 'kycFacebookPassword', 'kycSubmittedAt']) ||
        incoming().diff(existing()).affectedKeys().hasOnly(['pendingBalance']) ||
        incoming().diff(existing()).affectedKeys().hasOnly(['balance']) ||
        incoming().diff(existing()).affectedKeys().hasOnly(['referralStatus', 'pendingReferredBy']) ||
        incoming().diff(existing()).affectedKeys().hasOnly(['isAdmin'])
      )));
    }

    match /phone_index/{phone} {
      allow get: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /taskLogs/{logId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidTaskLog(incoming());
      allow update: if isAdmin();
    }

    match /transactions/{txId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidTransaction(incoming());
    }

    match /withdrawals/{wId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidWithdrawal(incoming()) && incoming().status == 'pending';
      allow update: if isAdmin();
    }

    match /orders/{orderId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidOrder(incoming());
      allow update: if isAdmin();
    }

    match /faqs/{faqId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /groupMessages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid && isValidGroupMessage(incoming());
      allow update: if isSignedIn() && (incoming().diff(existing()).affectedKeys().hasOnly(['readBy']) || isAdmin());
      allow delete: if isSignedIn() && (resource.data.senderId == request.auth.uid || isAdmin());
    }

    match /directMessages/{msgId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid && (request.auth.uid in incoming().participants) && isValidDirectMessage(incoming());
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants) && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow delete: if isAdmin();
    }

    match /typingIndicators/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && incoming().userId == request.auth.uid;
    }

    match /settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().sellerId == request.auth.uid && incoming().status == 'pending' && isValidProduct(incoming());
      allow update: if (isAdmin() || (isSignedIn() && resource.data.sellerId == request.auth.uid && incoming().status == resource.data.status && incoming().sellerId == resource.data.sellerId && isValidProduct(incoming())));
      allow delete: if isSignedIn() && (resource.data.sellerId == request.auth.uid || isAdmin());
    }

    match /serviceProviders/{providerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && incoming().userId == request.auth.uid);
    }

    match /serviceBookings/{bookingId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.providerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidServiceBooking(incoming());
      allow update: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.providerId == request.auth.uid) && isValidServiceBooking(incoming()));
      allow delete: if isAdmin();
    }

    match /courierOrders/{orderId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.riderId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidCourierOrder(incoming());
      allow update: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.riderId == request.auth.uid) && isValidCourierOrder(incoming()));
      allow delete: if isAdmin();
    }

    match /studentResources/{resourceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidStudentResource(incoming());
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid && isValidStudentResource(incoming()));
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /aiContentRequests/{requestId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidAIContentRequest(incoming());
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid && isValidAIContentRequest(incoming()));
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /aiAssets/{assetId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid && isValidAIAsset(incoming());
      allow update: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid && isValidAIAsset(incoming()));
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /globalNotifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /sellerShops/{shopId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && incoming().userId == request.auth.uid);
    }

    match /stories/{storyId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin());
    }

    match /liveStreams/{streamId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (incoming().creatorId == request.auth.uid || isAdmin());
    }

    match /mcqSets/{setId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin());
    }

    match /missions/{missionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /secretDeals/{dealId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /lootDrops/{dropId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && incoming().claimedBy == request.auth.uid);
    }

    match /skillTasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (incoming().userId == request.auth.uid || incoming().claimedBy == request.auth.uid || isAdmin());
    }

    match /iqGames/{gameId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /recharge-requests/{requestId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin());
    }

    match /userMissions/{missionId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin());
    }

    match /scratchCards/{cardId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin());
    }

    match /followers/{followId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (incoming().followerId == request.auth.uid || isAdmin());
    }

    match /virtualAssets/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (userId == request.auth.uid || isAdmin());
    }

    match /luckyNumbers/{numberId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin());
    }

    match /dailyChallenges/{challengeId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin());
    }
  }
}
